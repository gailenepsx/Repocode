    # 5) no direct Individual from spaCy anymore
    # 6) no direct Individual from names_dataset anymore
    ind = individual_score(raw, s, nlp_models, narr, nidx, pidx)

    r["spacy_vote_person"] = ind["vote"]["person_votes"]
    r["spacy_vote_org"] = ind["vote"]["org_votes"]
    r["spacy_vote_evidence"] = ind["vote"]["evidence"]
    if ind["names_match"]:
        r["best_names_dataset_match"] = ind["names_match"]
        r["best_names_dataset_score"] = ind["names_score"]

    if ind["score"] >= 6:
        r["predicted_entity_type"] = "Individual"
        r["classification_rule"] = "6_individual_evidence_score"
        r["classification_evidence"] = "; ".join(ind["reasons"])
        r["evidence"] = f"Individual because evidence score={ind['score']} | " + "; ".join(ind["reasons"])
        return r

    r["classification_rule"] = "7_other_cases_review"
    r["classification_evidence"] = f"insufficient individual evidence score={ind['score']}"
    r["evidence"] = (
        f"Review because evidence score={ind['score']} is insufficient; "
        + "; ".join(ind["reasons"])
    )
    return r
